@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using static System.Net.WebRequestMethods
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject HttpClient Http
@rendermode InteractiveServer


<EditForm OnValidSubmit="LoginAsync" Model="LoginForm">
    <label> email </label>
    <input @bind-value="LoginForm.Email" />
    <label> password </label>
    <input @bind-value="LoginForm.Password" />
    <button> Login </button>
</EditForm>

@code {

    private LoginForm LoginForm { get; set; } = new();

    private async Task LoginAsync()
    {
        var result = await Http.PostAsJsonAsync<LoginForm>("http://localhost:5179/auth/login", LoginForm);
        if ( result != null && result.IsSuccessStatusCode )
        {
            Console.WriteLine( "Logged in..." );
            NavigationManager.NavigateTo(uri: "/dashboard");
        }
        else
        {
            Console.WriteLine( "Failed to log in..." );
        }
    }
}