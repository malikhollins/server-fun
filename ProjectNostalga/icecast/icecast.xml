<icecast>
    <changeowner>
        <user>icecast</user>
        <group>icecast</group>
    </changeowner>
    <limits>
        <clients>100</clients>
        <sources>2</sources>
        <queue-size>102400</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65536</burst-size>
    </limits>
    <hostname>localhost</hostname>
    <location>Earth</location>
    <admin>admin@localhost</admin>
    <authentication>
        <source-password>hackme</source-password>
        <admin-user>admin</admin-user>
        <admin-password>hackme</admin-password>
    </authentication>
    <listen-socket>
        <port>8000</port>
        <bind-address>0.0.0.0</bind-address>
    </listen-socket>
    <http-headers>
        <header name="Access-Control-Allow-Origin" value="*" />
        <header name="Access-Control-Allow-Methods" value="GET, OPTIONS" />
        <header name="Access-Control-Allow-Headers"
            value="Origin, Icy-MetaData, Range, Authorization" />
        <header name="Access-Control-Expose-Headers"
            value="Icy-MetaInt, Icy-MetaData, Content-Type, Content-Length" />
    </http-headers>
    <mount>
        <mount-name>/stream</mount-name>
    </mount>
</icecast>